{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/mcpb/main/schemas/mcpb-manifest-v0.4.schema.json",
  "manifest_version": "0.4",
  "name": "sap-abap-mcp",
  "display_name": "SAP ABAP MCP",
  "version": "0.4.4",
  "description": "Develop, test, analyze, and operate SAP ABAP systems through ADT from AI coding agents.",
  "long_description": "A local-only MCP server for SAP ABAP development through the official ADT HTTP services. SAP profiles and credentials remain on the user's computer in macOS Keychain or Windows DPAPI. Configure and verify a profile before starting the bundle.",
  "author": {
    "name": "Coaspe",
    "url": "https://github.com/Coaspe"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Coaspe/sap-abap-mcp.git"
  },
  "homepage": "https://github.com/Coaspe/sap-abap-mcp",
  "documentation": "https://github.com/Coaspe/sap-abap-mcp#readme",
  "support": "https://github.com/Coaspe/sap-abap-mcp/issues",
  "privacy_policies": [
    "https://github.com/Coaspe/sap-abap-mcp/blob/main/PRIVACY.md"
  ],
  "icon": "icon.png",
  "server": {
    "type": "node",
    "entry_point": "server/index.mjs",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/server/index.mjs",
        "serve"
      ]
    }
  },
  "tools": [],
  "tools_generated": true,
  "keywords": [
    "sap",
    "abap",
    "adt",
    "developer-tools",
    "code-analysis",
    "code-execution"
  ],
  "license": "MIT",
  "compatibility": {
    "platforms": [
      "darwin",
      "win32"
    ],
    "runtimes": {
      "node": ">=20"
    }
  }
}
